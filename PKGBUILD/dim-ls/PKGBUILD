# Maintainer: dimunyx botnarudumitru10@gmail.com
# Contributor: -

pkgname=dim-ls
pkgver=0.0.6
pkgrel=3
pkgdesc="A fork of ls written in cpp instead of c"

arch=(
	'x86_64'
)

url="https://github.com/dimunyx/Cpp-projects/dim-ls"

license=(
	'GPL-3.0'
)

depends=(
	'gcc'
	'gcc-libs'
)

makedepends=(
	'gcc'
)

options=(
	'!debug'
)

build() {
    g++ -O3 -march=native -flto -std=c++20 \
        "$srcdir/main.cpp" \
        -o dim-ls
}

package() {
    install -Dm755 dim-ls "$pkgdir/usr/bin/dim-ls"
}
