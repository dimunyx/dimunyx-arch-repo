# Maintainer: dimunyx <botnarudumitru10@gmail.com>

pkgname=dimfetch
pkgver=0.3
pkgrel=1
pkgdesc="Minimalistic fetch written in cpp"

arch=('x86_64')
license=('GPL-3.0')

depends=('gcc-libs')
makedepends=('gcc')

options=('!debug')

source=("${pkgname}.cpp")
md5sums=('SKIP')

build() {
    g++ -march=x86-64 -O3 -flto -pipe \
        "$srcdir/${pkgname}.cpp" -o "${pkgname}"
}

package() {
    install -Dm755 "${srcdir}/${pkgname}" \
        "${pkgdir}/usr/bin/${pkgname}"
}
