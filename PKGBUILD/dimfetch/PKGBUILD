# Contributor: -

pkgname=dimfetch
pkgver=0.1
pkgrel=3
pkgdesc="dimunyx's own fetch"
arch=('x86_64')
url="https://github.com/dimunyx/Cpp-projects"
license=('GPL-3.0')
depends=('gcc-libs')
makedepends=('gcc')
options=('!debug')
source=('src/main.cpp')
sha256sums=('b6a324ea8ec6d8716bfbef15f856d7b8a5a4dbadc796ac10f3c6fc4fca885287')

build() {
  g++ -O3 -march=x86-64 -mtune=generic -flto -pipe -std=c++20 main.cpp -o dimfetch
}

package() {
  install -Dm755 dimfetch "$pkgdir/usr/bin/dimfetch"
}
